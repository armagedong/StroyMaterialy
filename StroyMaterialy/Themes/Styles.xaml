<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:conv="clr-namespace:StroyMaterialy.Converters">

    <conv:DiscountRowConverter x:Key="DiscountRowConverter"/>
    <conv:ImagePathConverter x:Key="ImagePathConverter"/>

    <SolidColorBrush x:Key="MainBackgroundBrush" Color="White"/>
    <SolidColorBrush x:Key="SecondaryBackgroundBrush" Color="#DAA520"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#B8860B"/>
    <SolidColorBrush x:Key="HighDiscountBrush" Color="#F4A460"/>

    <Style TargetType="Window">
        <Setter Property="FontFamily" Value="Calibri"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Background" Value="{StaticResource MainBackgroundBrush}"/>
    </Style>

    <Style TargetType="UserControl">
        <Setter Property="FontFamily" Value="Calibri"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Background" Value="{StaticResource MainBackgroundBrush}"/>
    </Style>

    <Style TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Calibri"/>
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="FontFamily" Value="Calibri"/>
        <Setter Property="Padding" Value="4,2"/>
        <Setter Property="Margin" Value="0,2,0,6"/>
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="FontFamily" Value="Calibri"/>
        <Setter Property="Margin" Value="0,2,0,6"/>
    </Style>

    <Style TargetType="DatePicker">
        <Setter Property="FontFamily" Value="Calibri"/>
        <Setter Property="Margin" Value="0,2,0,6"/>
    </Style>

    <Style x:Key="AccentButton" TargetType="Button">
        <Setter Property="FontFamily" Value="Calibri"/>
        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Padding" Value="16,6"/>
        <Setter Property="Margin" Value="4"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="FontFamily" Value="Calibri"/>
        <Setter Property="Background" Value="{StaticResource SecondaryBackgroundBrush}"/>
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="Padding" Value="16,6"/>
        <Setter Property="Margin" Value="4"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <Style TargetType="DataGrid">
        <Setter Property="FontFamily" Value="Calibri"/>
        <Setter Property="AutoGenerateColumns" Value="False"/>
        <Setter Property="IsReadOnly" Value="True"/>
        <Setter Property="CanUserAddRows" Value="False"/>
        <Setter Property="SelectionMode" Value="Single"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
        <Setter Property="GridLinesVisibility" Value="Horizontal"/>
        <Setter Property="AlternatingRowBackground" Value="#FFF8F0"/>
    </Style>

    <Style x:Key="ProductRowStyle" TargetType="DataGridRow">
        <Setter Property="Background" Value="White"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding HasHighDiscount}" Value="True">
                <Setter Property="Background" Value="{StaticResource HighDiscountBrush}"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
