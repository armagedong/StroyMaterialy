<Window x:Class="StroyMaterialy.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:StroyMaterialy.Views"
        Title="ООО «СтройМатериалы» — Главная"
        Icon="/Resources/icon.png"
        Height="720" Width="1100"
        WindowStartupLocation="CenterScreen"
        MinHeight="600" MinWidth="900">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#DAA520" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Image Grid.Column="0" Source="/Resources/picture.png" Height="64" Stretch="Uniform"/>
                <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="ООО «СтройМатериалы»" FontSize="22" FontWeight="Bold"/>
                    <TextBlock x:Name="UserInfoText" FontSize="14"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="ProductsNavButton" Content="Товары" Style="{StaticResource AccentButton}" Click="ProductsNav_Click"/>
                    <Button x:Name="OrdersNavButton" Content="Заказы" Style="{StaticResource SecondaryButton}" Click="OrdersNav_Click"/>
                    <Button Content="Выход" Style="{StaticResource SecondaryButton}" Click="Logout_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <ContentControl x:Name="ContentHost" Margin="8"/>
    </DockPanel>
</Window>
