<Window x:Class="StroyMaterialy.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ООО «СтройМатериалы» — Вход в систему"
        Icon="/Resources/icon.png"
        Height="420" Width="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Background="White" Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#DAA520" Margin="-24,-24,-24,16" Padding="16">
        <StackPanel>
            <Image Source="/Resources/picture.png" Height="72" Stretch="Uniform" HorizontalAlignment="Center"/>
            <TextBlock Text="ООО «СтройМатериалы»" FontSize="20" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,8,0,0"/>
            <TextBlock Text="Магазин строительных материалов" HorizontalAlignment="Center"/>
        </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" VerticalAlignment="Center">
            <TextBlock Text="Логин"/>
            <TextBox x:Name="LoginTextBox"/>
            <TextBlock Text="Пароль"/>
            <PasswordBox x:Name="PasswordBox" FontFamily="Calibri" Padding="4,2" Margin="0,2,0,6"/>
            <TextBlock x:Name="ErrorText" Foreground="Red" TextWrapping="Wrap" Visibility="Collapsed"/>
        </StackPanel>

        <StackPanel Grid.Row="2">
            <Button Content="Войти" Style="{StaticResource AccentButton}" Click="Login_Click"/>
            <Button Content="Войти как гость" Style="{StaticResource SecondaryButton}" Click="Guest_Click"/>
        </StackPanel>
    </Grid>
</Window>
