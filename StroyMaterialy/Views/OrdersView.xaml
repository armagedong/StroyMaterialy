<UserControl x:Class="StroyMaterialy.Views.OrdersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Заказы" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>

        <DataGrid x:Name="OrdersGrid" Grid.Row="1" SelectionChanged="OrdersGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="№" Binding="{Binding OrderNumber}" Width="50"/>
                <DataGridTextColumn Header="Дата заказа" Binding="{Binding OrderDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                <DataGridTextColumn Header="Дата выдачи" Binding="{Binding DeliveryDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                <DataGridTextColumn Header="Пункт выдачи" Binding="{Binding PickupAddress}" Width="*"/>
                <DataGridTextColumn Header="Клиент" Binding="{Binding ClientFullName}" Width="180"/>
                <DataGridTextColumn Header="Код" Binding="{Binding PickupCode}" Width="60"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="100"/>
                <DataGridTextColumn Header="Состав" Binding="{Binding ItemsDescription}" Width="200"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel x:Name="AdminPanel" Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Добавить" Style="{StaticResource AccentButton}" Click="Add_Click"/>
            <Button Content="Изменить" Style="{StaticResource SecondaryButton}" Click="Edit_Click"/>
            <Button Content="Удалить" Style="{StaticResource SecondaryButton}" Click="Delete_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
