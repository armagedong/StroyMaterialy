<UserControl x:Class="StroyMaterialy.Views.ProductsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border x:Name="FilterPanel" Grid.Row="0" Background="#DAA520" Padding="8" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="4">
                    <TextBlock Text="Поиск"/>
                    <TextBox x:Name="SearchBox" TextChanged="Filter_Changed"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="4">
                    <TextBlock Text="Категория"/>
                    <ComboBox x:Name="CategoryFilter" SelectionChanged="Filter_Changed"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Margin="4">
                    <TextBlock Text="Поставщик"/>
                    <ComboBox x:Name="SupplierFilter" SelectionChanged="Filter_Changed"/>
                </StackPanel>
                <StackPanel Grid.Column="3" Margin="4">
                    <TextBlock Text="Сортировка"/>
                    <ComboBox x:Name="SortCombo" SelectionChanged="Filter_Changed"/>
                </StackPanel>
                <Button Grid.Column="4" Content="Сбросить" Style="{StaticResource SecondaryButton}"
                        VerticalAlignment="Bottom" Click="ResetFilters_Click"/>
            </Grid>
        </Border>

        <DataGrid x:Name="ProductsGrid" Grid.Row="1" RowStyle="{StaticResource ProductRowStyle}"
                  SelectionChanged="ProductsGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Артикул" Binding="{Binding Article}" Width="80"/>
                <DataGridTemplateColumn Header="Фото" Width="70">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Image Source="{Binding ImageFile, Converter={StaticResource ImagePathConverter}}"
                                   Height="48" Stretch="Uniform"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Категория" Binding="{Binding Category}" Width="160"/>
                <DataGridTextColumn Header="Производитель" Binding="{Binding Manufacturer}" Width="120"/>
                <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat={}{0:N2} ₽}" Width="90"/>
                <DataGridTextColumn Header="Скидка %" Binding="{Binding DiscountPercent}" Width="80"/>
                <DataGridTextColumn Header="Цена со скидкой" Binding="{Binding FinalPrice, StringFormat={}{0:N2} ₽}" Width="110"/>
                <DataGridTextColumn Header="На складе" Binding="{Binding QuantityInStock}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel x:Name="AdminPanel" Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Добавить" Style="{StaticResource AccentButton}" Click="Add_Click"/>
            <Button Content="Изменить" Style="{StaticResource SecondaryButton}" Click="Edit_Click"/>
            <Button Content="Удалить" Style="{StaticResource SecondaryButton}" Click="Delete_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
