<Window x:Class="StroyMaterialy.Views.ProductEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Товар — редактирование"
        Height="560" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="16">
        <StackPanel>
            <TextBlock Text="Артикул"/><TextBox x:Name="ArticleBox"/>
            <TextBlock Text="Наименование"/><TextBox x:Name="NameBox"/>
            <TextBlock Text="Ед. изм."/><TextBox x:Name="UnitBox"/>
            <TextBlock Text="Цена"/><TextBox x:Name="PriceBox"/>
            <TextBlock Text="Поставщик"/><TextBox x:Name="SupplierBox"/>
            <TextBlock Text="Производитель"/><TextBox x:Name="ManufacturerBox"/>
            <TextBlock Text="Категория"/><TextBox x:Name="CategoryBox"/>
            <TextBlock Text="Скидка %"/><TextBox x:Name="DiscountBox"/>
            <TextBlock Text="Количество на складе"/><TextBox x:Name="QuantityBox"/>
            <TextBlock Text="Описание"/><TextBox x:Name="DescriptionBox" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>
            <TextBlock Text="Файл изображения"/><TextBox x:Name="ImageBox"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button Content="Сохранить" Style="{StaticResource AccentButton}" Click="Save_Click"/>
                <Button Content="Отмена" Style="{StaticResource SecondaryButton}" IsCancel="True"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
